# ============================================================
# MestreGrana - Arquivo de Configuração (.env)
# INSTRUÇÃO: Copie este arquivo como ".env" e preencha suas chaves
# ============================================================

# ===== 🤖 APIs DE IA =====
# Groq (Grátis) - https://console.groq.com
GROQ_API_KEY=gsk_sua_chave_groq_aqui

# Google Gemini (Grátis) - https://makersuite.google.com/app/apikey
GEMINI_API_KEY=sua_chave_gemini_aqui

# OpenAI (Pago) - https://platform.openai.com/api-keys
OPENAI_API_KEY=sk_sua_chave_openai_aqui

# ===== 🗄️ NEON DATABASE (PostgreSQL) =====
# Crie conta em https://neon.tech
# Copie a CONNECTION STRING completa (incluindo ?sslmode=require)
DATABASE_URL=postgresql://user_abc:password123@ep-cool-db-123.us-east-1.neon.tech/mestregrana?sslmode=require

# ===== 🍃 MONGODB ATLAS (Opcional) =====
# Crie cluster em https://www.mongodb.com/cloud/atlas
# Copie a connection string do cluster
# MONGODB_ATLAS_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority

# ===== 🔐 CONFIGURAÇÕES OPCIONAIS =====
# Chave para encriptação (gerar com: python -c "import secrets; print(secrets.token_hex(32))")
# SECRET_KEY=sua_chave_secreta_32_caracteres

# Ambiente (development, staging, production)
ENVIRONMENT=development

# Moeda padrão
DEFAULT_CURRENCY=BRL

# Fuso horário
TIMEZONE=America/Sao_Paulo
